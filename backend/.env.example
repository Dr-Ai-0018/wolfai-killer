# AI Werewolf Backend Environment Variables

# API Configuration
WEREWOLF_API_KEY=your_api_key_here
WEREWOLF_API_BASE_URL=https://api.killerbest.com/v1

# Admin Authentication (REQUIRED)
WEREWOLF_ADMIN_PASSWORD=your_admin_password_here
# JWT Secret Key (auto-generated if not set, but recommended to set for persistence)
WEREWOLF_JWT_SECRET=your_jwt_secret_key_here
# JWT Token expiry in hours (default: 24)
WEREWOLF_JWT_EXPIRY_HOURS=24

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Database
DATABASE_PATH=./logs/games.db
